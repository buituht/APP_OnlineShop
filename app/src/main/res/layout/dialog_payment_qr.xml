<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="@android:color/white">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_gallery"
        android:layout_marginBottom="16dp"
        app:tint="@color/purple_main" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUÉT MÃ ĐỂ THANH TOÁN"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <androidx.cardview.widget.CardView
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F8F9FA">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="15dp">

            <ImageView
                android:id="@+id/img_qr_code"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_dialog_info" />

            <!-- Hiệu ứng quét -->
            <View
                android:id="@+id/view_scan_line"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/purple_main"
                android:alpha="0.7" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_payment_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="0 VNĐ"
        android:textSize="24sp"
        android:textColor="@color/purple_main"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Hệ thống đang chờ xác nhận..."
        android:textSize="13sp"
        android:textColor="#888888" />

    <ProgressBar
        android:id="@+id/pb_payment_processing"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_payment_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Vui lòng mở App Ngân hàng hoặc Ví điện tử"
        android:textSize="12sp"
        android:textColor="@color/gray_text" />

</LinearLayout>