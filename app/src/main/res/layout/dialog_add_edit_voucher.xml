<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/et_voucher_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã Voucher (VD: WELCOME10)"
            android:inputType="textCapCharacters" />

        <EditText
            android:id="@+id/et_voucher_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Mô tả"
            android:inputType="text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Loại giảm giá" />

        <Spinner
            android:id="@+id/sp_voucher_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/et_voucher_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Giá trị giảm (Số tiền hoặc %)"
            android:inputType="number" />

        <EditText
            android:id="@+id/et_voucher_min_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Đơn hàng tối thiểu"
            android:inputType="number" />

        <EditText
            android:id="@+id/et_voucher_start_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Ngày bắt đầu (dd/MM/yyyy)"
            android:focusable="false"
            android:clickable="true" />

        <EditText
            android:id="@+id/et_voucher_expiry_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Ngày hết hạn (dd/MM/yyyy)"
            android:focusable="false"
            android:clickable="true" />

    </LinearLayout>
</ScrollView>