<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header / Top Menu -->
    <LinearLayout
        android:id="@+id/header_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_main"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back_detail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="CHI TIẾT SẢN PHẨM"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_favorite_detail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_heart_outline"
            app:tint="@color/white"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:visibility="visible" />

        <FrameLayout
            android:id="@+id/btn_cart_detail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/white" />
        </FrameLayout>
    </LinearLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header_detail"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image Gallery Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F8F8">

                <ImageView
                    android:id="@+id/img_detail"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:scaleType="centerInside"
                    android:padding="20dp"/>

                <!-- Thumbnail List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_product_images"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:text="Tên sản phẩm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tv_detail_discount_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/red"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:text="0 VNĐ"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_detail_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/gray_text"
                        android:textSize="18sp"
                        android:text="0 VNĐ" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_to_cart_detail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:text="THÊM VÀO GIỎ HÀNG"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#444444"
                    app:cornerRadius="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông số kỹ thuật"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins">

                    <TextView
                        android:id="@+id/tv_spec_screen"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_screen"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Màn hình: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_cpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_cpu"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Chip: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_ram"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_ram"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="RAM: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_rom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_rom"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Bộ nhớ: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_camera"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_camera"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Camera: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_battery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@drawable/ic_battery"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Pin: --"
                        android:textColor="@color/black"
                        android:padding="8dp"/>

                    <TextView
                        android:id="@+id/tv_spec_warranty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:drawableStart="@android:drawable/ic_menu_agenda"
                        android:drawablePadding="12dp"
                        android:gravity="center_vertical"
                        android:text="Bảo hành: --"
                        android:textColor="@color/black"
                        android:padding="8dp"
                        app:tint="@color/black"/>
                </GridLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả sản phẩm"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_detail_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:text="Mô tả chi tiết đang cập nhật..." />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="20dp"/>

                <!-- Products from Admin Section -->
                <TextView
                    android:id="@+id/tv_title_admin_products"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sản phẩm liên quan"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <com.example.myapplication.NonScrollListView
                    android:id="@+id/lv_admin_products"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:nestedScrollingEnabled="false" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="20dp"/>

                <!-- Review Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá sản phẩm"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Add Review Area -->
                <LinearLayout
                    android:id="@+id/layout_add_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="#F9F9F9"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viết đánh giá của bạn"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <RatingBar
                        android:id="@+id/rb_input_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:rating="5"
                        android:theme="@style/RatingBar" />

                    <EditText
                        android:id="@+id/et_input_comment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nhập bình luận của bạn..."
                        android:textColor="@color/black"
                        android:textColorHint="@color/gray_text"
                        android:background="@drawable/rounded_input_bg"
                        android:padding="12dp"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:minLines="3"
                        android:gravity="top"/>

                    <!-- Image Pick Button -->
                    <LinearLayout
                        android:id="@+id/btn_pick_review_images"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_input_bg"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/gray_text" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Thêm hình ảnh thực tế"
                            android:textColor="@color/gray_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Danh sách ảnh đã chọn cho Review -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_review_selected_images"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_submit_review"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="Gửi đánh giá"
                        android:textSize="12sp"
                        android:backgroundTint="#444444"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <!-- Review List -->
                <com.example.myapplication.NonScrollListView
                    android:id="@+id/lv_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/black"
        app:itemTextColor="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>
